<?xml version='1.0' encoding='utf-8' ?>
<manifest manifest-version='0.1' xmlns='http://www.tableau.com/xml/extension_manifest'>
  <worksheet-extension id='com.vizyourdata.heatmap' extension-version='1.0.0'>
    <default-locale>en_US</default-locale>
    <name resource-id='name'/>
    <description>Calendar Heatmap — dates laid out as a weeks × weekdays grid, each cell colored by a measure, with marginal sum bars showing weekly (top) and weekday (side) totals. Drop a date on Date and a measure on Value.</description>
    <author name='vizyourdata'
            email='eric.summers@vizyourdata.com'
            organization='vizyourdata'
            website='https://tableauops.com'/>
    <min-api-version>1.12</min-api-version>
    <source-location>
      <!-- Tableau Desktop allows http://localhost. Tableau Cloud/Server require HTTPS. -->
      <url>http://localhost:1111/heatmap/heatmap.html</url>
    </source-location>
    <icon>iVBORw0KGgoAAAANSUhEUgAAABAAAAAQCAYAAAAf8/9hAAAABmJLR0QA/wD/AP+gvaeTAAAACXBIWXMAAAsTAAALEwEAmpwYAAAAB3RJTUUH4QkQFg0b8MBEbAAAAB1pVFh0Q29tbWVudAAAAAAAQ3JlYXRlZCB3aXRoIEdJTVBkLmUHAAAA3klEQVQ4y2NgGAWjgB7g////KwaGb8b/////YYBIDsT///8DAOZlFRU=</icon>
    <context-menu>
      <configure-context-menu-item />
    </context-menu>
    <encoding id='date'>
        <display-name>Date</display-name>
        <!-- No <data-spec>: the manifest schema only allows string/numeric/boolean
             data-types, so restricting to one would block real date fields. Omitting
             it lets any field type drop here; role-spec keeps it a dimension. -->
        <role-spec>
          <role-type>discrete-dimension</role-type>
          <role-type>continuous-dimension</role-type>
        </role-spec>
        <fields max-count='1'/>
        <encoding-icon token='letter-d' />
        <tooltip>Date field that defines each cell in the calendar grid.</tooltip>
      </encoding>
      <encoding id='value'>
        <display-name>Value</display-name>
        <data-spec>
          <data-type>numeric</data-type>
        </data-spec>
        <role-spec>
          <role-type>continuous-measure</role-type>
        </role-spec>
        <fields max-count='1'/>
        <encoding-icon token='letter-v' />
        <tooltip>Measure that colors each cell and feeds the marginal sum bars.</tooltip>
      </encoding>
  </worksheet-extension>
  <resources>
    <resource id='name'>
      <text locale='en_US'>Calendar Heatmap</text>
    </resource>
  </resources>
</manifest>
